{
  "name": "@vibegameengine/shader-warmup",
  "version": "1.0.3",
  "description": "Pre-compile Three.js shaders to prevent runtime stutter (jank) in React Three Fiber apps",
  "license": "MIT",
  "keywords": [
    "three",
    "threejs",
    "shader",
    "warmup",
    "react-three-fiber",
    "r3f",
    "performance"
  ],
  "homepage": "https://github.com/vibegameengine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibegameengine/shader-warmup.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "@react-three/fiber": "8.15.16",
    "@types/react": "^18.2.0",
    "@types/three": "^0.161.0",
    "react": "18.2.0",
    "three": "0.161.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
